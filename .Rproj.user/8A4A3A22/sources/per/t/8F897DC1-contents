# Load libraries
library(ape)
library(ggtree)
library(dplyr)
library(RColorBrewer)
library(ggplot2)
library(ggnewscale)
library(treeio)
library(scales)  # For handling custom palettes

# Read the tree file
tree_file <- "/Users/hugo/Desktop/Rhados_v3_alig.tree"
phy <- read.tree(file = tree_file)
phy <- midpoint.root(phy)  # Ensure the tree is properly rooted

# Load the genotype table
genotype_table <- read.csv("/Users/hugo/virus_table.csv")

# Ensure tree labels match the dataframe
md <- genotype_table[match(phy$tip.label, genotype_table$Name), ]

if (!all(phy$tip.label %in% md$Name)) {
  stop("Tree labels do not match those in the dataframe.")
}

# Assign genotypes to tree labels
genotype_vector <- md$Genotype[match(phy$tip.label, md$Name)]
accession <- genotype_table$Accession[match(phy$tip.label, genotype_table$Name)]

# Create a palette of 53 distinct colors using colorRampPalette
custom_palette <- colorRampPalette(brewer.pal(9, "Set1"))(53)  # Using 'Set1' to generate additional colors

# Fortify the tree for use with ggplot2
fortified_tree <- fortify(phy)

# Ensure colors are properly assigned to labels
fortified_tree$Genotype <- rep(genotype_vector, length.out = nrow(fortified_tree))
fortified_tree$Accession <- rep(accession, length.out = nrow(fortified_tree))

# Build the tree plot
p <- ggtree(fortified_tree) + 
  geom_tree(aes(color = "gray90"), size = 0.5) +  # Gray tree
  geom_tiplab(aes(color = Genotype), size = 2) +  # Smaller labels
  scale_color_manual(values = setNames(custom_palette, unique(md$Genotype))) +   # Custom colors for genotypes
  theme_tree() +
  theme(
    legend.position = "right",        # Legend on the right
    legend.key = element_blank()      # Remove background in the legend
  ) + 
  guides(color = guide_legend(override.aes = list(shape = 19, size = 4))) +  # Points in the legend, not on the tree
  labs(color = "Genus")  # Change legend title to "Genus"

# Display the plot
print(p)

# Create a simple tree plot with aligned labels, tip colors, and small text
p <- ggtree(fortified_tree, layout = "rectangular") +
  geom_tree(color = "gray67", size = 0.5) +  # Tree with gray branches
  geom_tiplab(
    data = fortified_tree %>% filter(isTip),  # Apply only to tips
    aes(label = Genotype, color = Genotype), 
    size = 0.5,  # Small font size for labels
    align = TRUE
  ) +  # Aligned labels colored by Genotype
  scale_color_manual(
    values = setNames(custom_palette, unique(md$Genotype)),  # Custom colors for each genotype
    na.translate = FALSE  # Avoid empty categories in the legend
  ) +
  theme_tree() +  # Basic ggtree theme without visible x-axis
  theme(
    legend.position = "right",        # Legend positioned on the right
    legend.key = element_blank(),     # No background in the legend
    plot.margin = margin(3, 20, 0, 3) # Custom margins
  ) +
  labs(color = "Rhabdoviridae Genus")

# Add points only to the tips
p <- p + geom_point(
  data = fortified_tree %>% filter(isTip),  
  aes(color = Genotype), 
  size = 2
)

# Display the plot
print(p)
