load.spr <- function(fn) {
  spr <- read.csv(fn)
  
  # Extract segment name
  segment <- strsplit(basename(fn), "_")[[1]][3]
  
  # Real data (remover filas con NA en HA_real)
  df_real <- data.frame(type="real", branches=spr[,1], 
                        ref=spr$HA_real, query=spr[,3])
  df_real <- df_real[!is.na(df_real$branches) & !is.na(df_real$ref), ]
  
  # Simulated data (remover filas con NA en HA_real.1)
  df_sim <- data.frame(type="simulated", branches=spr[,4], 
                       ref=spr$HA_real.1, query=spr[,6])
  df_sim <- df_sim[!is.na(df_sim$branches) & !is.na(df_sim$ref), ]
  
  # Combine real and simulated data
  df <- rbind(df_real, df_sim)
  
  # Add segment information
  df$segment <- segment
  df
}

