library(ggplot2)
library(ggtree)
library(ggnewscale)
library(treeio)
library(RColorBrewer)
library(phytools)     # midpoint root
library(svglite)

# Location of work directory
#setwd("/Users/jorgerv/Documents/Colab_INSP/")

## -----------------------------------------------
##
## Upload the metadata and the reconstructed tree
##
## -----------------------------------------------

# Cargar los metadatos
md <- read.csv("/Users/hugo/Downloads/metadata_v3.csv")
rownames(md) <- md$ID  # Asegúrate de que las filas del dataframe coincidan con los nombres de las puntas

## Cargar el árbol de iqtree del core presente en el 100% de genomas
phy <- read.tree("/Users/hugo/Desktop/aligned_concatenated.fasta.tree")

## Enraizar el árbol al punto medio
phy <- midpoint.root(phy)

# Asegurarse de que los nombres de las puntas del árbol coincidan con los del dataframe
md <- md[match(phy$tip.label, md$ID), ]

# Verifica si las etiquetas están correctamente alineadas
if (!all(phy$tip.label %in% rownames(md))) {
  stop("Las etiquetas del árbol no coinciden con las del dataframe.")
}

## ------------------------------------------
##
## Arbol con Source como heatmap
##
## ------------------------------------------

# Fortificar el árbol para obtener coordenadas de nodos y puntas
fortified_tree <- fortify(phy)

# Combinar las coordenadas del árbol con los metadatos
#tips_data <- merge(fortified_tree[fortified_tree$isTip, ], md, by.x = "label", by.y = "ID")
tips_data <- merge(fortified_tree[fortified_tree$isTip, ], md, by.x = "label", by.y = "ID")
head(tips_data)
# Crear el layout circular del árbol
circ <- ggtree(phy, layout = "circular", branch.length = "none", size = 0.2)
# Crear layout circular del árbol
#circ <- ggtree(phy, layout = "circular", branch.length = "none", size = 0.2)

# Añadir etiquetas desde los datos fusionados
circ <- circ + geom_tiplab(data = tips_data, aes(label = species), size = 2, align = TRUE)
#Mostrar el gráfico final
print(circ)


# Calcular los ángulos para las etiquetas
circ_data <- circ$data
circ_data$angle <- with(circ_data, ifelse(isTip, 90 - (y / max(y) * 360), NA))

# Ajustar los ángulos para que las etiquetas no estén al revés
circ_data$angle <- with(circ_data, ifelse(angle < -90, angle + 180, angle))

# Añadir las etiquetas dentro del árbol
circ <- circ + 
  geom_text(data = circ_data[circ_data$isTip, ], 
            aes(x = x * 0.85, y = y, angle = angle), # Escalar x hacia adentro
            size = 2.5, hjust = 0.5) + 
  theme_tree2()


# Generar colores automáticos para las categorías de 'Source'
source_colors <- scale_fill_manual(values = setNames(md$source_color, md$Source))

# Mapa de calor para la columna Source con colores automáticos
p1 <- gheatmap(circ, md["Source"], offset = 0.8, width = 0.05, colnames = FALSE) +
  source_colors +  # Colores categóricos para 'Source'
  theme(legend.position = "right")  # Ajusta la posición de la leyenda

# Añadir nueva escala de relleno antes del siguiente mapa de calor
p1 <- p1 + new_scale_fill()

# Convertir 'Viral' a numérico si aún no lo es
md$Viral <- as.numeric(md$Viral)

# Mapa de calor para la columna Viral
p1 <- gheatmap(p1, md["Viral", drop = FALSE], offset = 1.5, width = 0.05, colnames = FALSE) +
  scale_fill_gradient(low = "white", high = "red", na.value = "gray") +  # Gradiente para 'Viral'
  theme(legend.position = "right")

# Mostrar el gráfico final
print(p1)

# Guardar el gráfico
svglite("tree_gene_markers_with_source_and_viral_heatmap.svg", width = 15, height = 10)
print(p1)
dev.off()




