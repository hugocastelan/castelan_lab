library(ggplot2)
# Convertir a data frame
data <- data.frame(
Segment = rep(c("NA", "NP", "MP", "NS", "PA", "PB1", "PB2"), each = 2),
Type = rep(c("Real", "Simulations"), 7),
Value = c(91.4, 62.5, 84.5, 44.4, 87.4, 62.5,
85.6, 62.5, 89.4, 60.0, 88.1, 50.0, 87.9, 66.7)
)
# Gráfico de líneas
ggplot(data, aes(x = Segment, y = Value, group = Type, color = Type)) +
geom_line(size = 1) +
geom_point(size = 3) +
theme_minimal() +
labs(title = "Comparison of Real vs. Simulations",
x = "Segment", y = "Value") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Gráfico de dispersión con líneas conectadas
ggplot(data, aes(x = Type, y = Value, group = Segment, color = Segment)) +
geom_line(size = 1) +
geom_point(size = 3) +
theme_minimal() +
labs(title = "Slope Graph: Real vs. Simulations",
x = "Type", y = "Value") +
theme(axis.text.x = element_text(angle = 0, hjust = 0.5))
data <- data.frame(
Segment = rep(c("NA", "NP", "MP", "NS", "PA", "PB1", "PB2"), each = 2),
Type = rep(c("Real", "Simulations"), 7),
