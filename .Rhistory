axis.title = element_text(size = 14),
axis.text = element_text(size = 12),
panel.spacing = unit(0.1, "lines"),  # Reducir el espacio entre paneles
panel.grid.major = element_blank(),  # Eliminar las líneas de la cuadrícula principal
panel.grid.minor = element_blank(),  # Eliminar las líneas de la cuadrícula secundaria
axis.line = element_line(color = "black"),  # Añadir líneas de ejes
plot.margin = margin(0.5, 0.5, 0.5, 0.5, "cm")  # Ajustar los márgenes del gráfico
)
print(p)
library(ggplot2)
library(ggridges)
# Ordenar los segmentos en el factor
full.df$segment <- factor(full.df$segment, levels = c("PB2", "PB1", "PA", "NS", "NP", "NA", "MP"))
p <- ggplot(full.df, aes(x = ref, y = segment, fill = group, color = group)) +
geom_density_ridges(alpha = 0.6, scale = 1, rel_min_height = 0) +
scale_fill_manual(values = c("Single, real" = "blue", "Single, simulated" = "red",
"Multiple, real" = "darkblue", "Multiple, simulated" = "darkred")) +
scale_color_manual(values = c("Single, real" = "blue", "Single, simulated" = "red",
"Multiple, real" = "darkblue", "Multiple, simulated" = "darkred")) +
facet_wrap(~ segment, scales = "free", ncol = 4) +  # Ajusta el número de columnas
theme_minimal(base_size = 14) +
labs(x = "Sibling distance", y = "Density", fill = "Group", color = "Group") +
theme(strip.text = element_text(size = 14, face = "bold"),
legend.position = "right",
legend.title = element_text(size = 12),
legend.text = element_text(size = 10),
axis.title = element_text(size = 14),
axis.text = element_text(size = 12),
panel.spacing = unit(1, "lines"),
panel.background = element_rect(fill = "black"))  # Fondo negro opcional
print(p)
