# Cargar librerías necesarias
library(ggplot2)
library(reshape2)
# Definir los datos en un data frame
datos <- data.frame(
Segmento = c("MP", "NA", "NP", "NS", "PA", "PB1", "PB2"),
Tree_real = c(3.85394, 22.35337, 5.92746, 5.14603, 6.39336, 6.24237, 6.87354),
Pyvolve = c(4.45876, 24.56931, 6.84717, 5.84755, 7.27681, 7.17356, 7.70762),
Phastsim = c(2.83704, 18.15167, 3.50514, 4.19227, 5.20735, 5.14145, 5.36897),
Gen_Seq = c(7.76289, 24.88359, 5.85289, 6.82014, 4.4771, 6.97141, 7.28272),
Alisim = c(6.53502, 23.31121, 8.57326, 7.03849, 9.08877, 8.72428, 9.61774)
)
# Transformar datos a formato largo para ggplot
datos_largos <- melt(datos, id.vars = "Segmento", variable.name = "Método", value.name = "Valor")
# Crear el gráfico de barras
ggplot(datos_largos, aes(x = Segmento, y = Valor, fill = Método)) +
geom_bar(stat = "identity", position = "dodge") +
theme_minimal() +
labs(title = "Comparación de Métodos por Segmento",
x = "Segmento",
y = "Valor",
fill = "Método") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Load necessary libraries
library(ggplot2)
library(reshape2)
library(viridis)  # For a better color palette
# Define the data frame
data <- data.frame(
Segment = c("MP", "NA", "NP", "NS", "PA", "PB1", "PB2"),
Tree_Real = c(3.85394, 22.35337, 5.92746, 5.14603, 6.39336, 6.24237, 6.87354),
Pyvolve = c(4.45876, 24.56931, 6.84717, 5.84755, 7.27681, 7.17356, 7.70762),
Phastsim = c(2.83704, 18.15167, 3.50514, 4.19227, 5.20735, 5.14145, 5.36897),
Gen_Seq = c(7.76289, 24.88359, 5.85289, 6.82014, 4.4771, 6.97141, 7.28272),
Alisim = c(6.53502, 23.31121, 8.57326, 7.03849, 9.08877, 8.72428, 9.61774)
)
# Convert to long format for ggplot
data_long <- melt(data, id.vars = "Segment", variable.name = "Method", value.name = "Value")
# Create the barplot
ggplot(data_long, aes(x = Segment, y = Value, fill = Method)) +
geom_bar(stat = "identity", position = "dodge") +
scale_fill_viridis(discrete = TRUE, option = "plasma") +  # Change color palette
theme_minimal() +
labs(title = "Comparison of Methods by Segment",
x = "Segment",
y = "Value",
fill = "Method") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
