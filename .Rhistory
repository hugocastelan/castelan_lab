geom_line(size = 1) +
geom_point(size = 3) +
theme_minimal() +
labs(title = "SPRs involve changes in only one branch",
x = "Type", y = "Percentaje") +
theme(axis.text.x = element_text(angle = 0, hjust = 0.5))
