library(ggplot2)
library(dplyr)
library(tidyr)
# Crear los datos
data <- data.frame(
Segmento = c("HA-NA", "HA-NP", "HA-MP", "HA-NS", "HA-PA", "HA-PB1", "HA-PB2"),
Real = c(91.4, 84.5, 87.4, 85.6, 89.4, 88.1, 87.9),
Simulado = c(62.5, 44.4, 62.5, 62.5, 60.0, 50.0, 66.7)
)
# Transformar a formato largo
data_long <- data %>%
pivot_longer(cols = c("Real", "Simulado"), names_to = "Tipo", values_to = "Valor")
# Crear el slope graph
ggplot(data_long, aes(x = Tipo, y = Valor, group = Segmento, label = Segmento)) +
geom_line(aes(color = Segmento), size = 1) +
geom_point(aes(color = Segmento), size = 3) +
geom_text(aes(label = round(Valor, 1)), vjust = -0.5, size = 5) +
theme_minimal() +
labs(title = "Comparación de valores reales vs simulados",
y = "Porcentaje",
x = "") +
theme(legend.position = "none")
library(ggfree)
# Crear la tabla como matriz
tab <- matrix(c(
91.4, 62.5,
84.5, 44.4,
87.4, 62.5,
85.6, 62.5,
89.4, 60.0,
88.1, 50.0,
87.9, 66.7
), ncol = 2, byrow = TRUE)
# Agregar nombres de fila y columna
rownames(tab) <- c("HA-NA", "HA-NP", "HA-MP", "HA-NS", "HA-PA", "HA-PB1", "HA-PB2")
colnames(tab) <- c("Real", "Simulado")
# Generar el slope graph
slopegraph(tab[,1], tab[,2], col = TRUE, names.arg = colnames(tab))
